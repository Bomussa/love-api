{
  "name": "love-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Medical Committee API - Backend Serverless Functions",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0"
  },
  "scripts": {
    "build": "node -e \"console.log('love-api: no build step required')\"",
    "test": "npm run test:unit && npm run test:contracts",
    "test:unit": "vitest run lib/*.test.ts",
    "test:contracts": "node --test tests/*.test.js",
    "check:queue-contract": "node scripts/check-queue-contract.js",
    "check:endpoint-contracts": "node scripts/check-endpoint-contracts.js",
    "check:schema-contract": "node scripts/check-schema-contract.js",
    "test:smoke:mmc": "bash scripts/smoke-mmc-domains.sh"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
