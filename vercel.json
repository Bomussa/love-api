{
  "version": 2,
  "functions": {
    "api/v1.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/v1.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/v1.js"
    },
    {
      "src": "/api/status",
      "dest": "/api/v1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/v1.js"
    }
  ],
  "env": {
    "SUPABASE_URL": "https://rujwuruuosffcxazymit.supabase.co",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase-service-role-key"
  }
}
